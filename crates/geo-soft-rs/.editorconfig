root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Preserve trailing whitespace in SOFT fixture files (TSV format)
[tests/fixtures/**/*.soft]
trim_trailing_whitespace = false

# Also preserve in any other fixture files
[tests/fixtures/**/*]
trim_trailing_whitespace = false
